    "    #       ├── pushup_middle/       \n",
    "    #       ├── pushup_start/  \n",
    "    #       ├── situp_middle/\n",
    "    #       ├── situp_start/  \n",
    "    #       ├── squat_middle/       \n",
    "    #       └── squat_start/            \n",
    "    X_data = []\n",
    "    y_data = []\n",
<<<<<<< HEAD
